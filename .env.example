# ────────────────────────────────────────────
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요.
# cp .env.example .env
# .env 파일은 절대 Git에 올리지 마세요.
# ────────────────────────────────────────────

NAVER_CLIENT_ID=여기에_클라이언트_ID_입력
NAVER_CLIENT_SECRET=여기에_클라이언트_시크릿_입력

# 로컬 개발 시 기본값은 http://localhost:8501
# 배포 시 실제 도메인으로 변경하세요
NAVER_REDIRECT_URI=http://localhost:8501
